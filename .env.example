# Pi 配置文件
# 复制此文件为 .env 并填入你的值

# API Key（必填）
ANTHROPIC_API_KEY=your_api_key_here

# API Base URL（可选）
# 使用 DeepSeek (Anthropic 兼容接口): https://api.deepseek.com/anthropic
# 使用 OpenRouter: https://openrouter.ai/api/v1
# 留空则使用 Anthropic 官方 API
PI_BASE_URL=https://api.deepseek.com/anthropic

# 模型名称（可选）
# DeepSeek: deepseek-chat / deepseek-reasoner
# Anthropic: claude-opus-4-5 / claude-sonnet-4-5
PI_MODEL=deepseek-chat

# 系统提示词缓存（可选）
# 启用后会在静态和动态内容之间插入边界标记，支持 Anthropic API 的 prompt caching
# 设置为 true 启用，默认为 false
USE_GLOBAL_CACHE_SCOPE=false
