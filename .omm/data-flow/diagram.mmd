graph LR
    classDef entry fill:#89b4fa,stroke:#89b4fa,color:#1e1e2e
    classDef external fill:#585b70,stroke:#585b70,color:#cdd6f4
    classDef store fill:#a6e3a1,stroke:#a6e3a1,color:#1e1e2e

    user-input["User Input\nPromptInput / Feishu message"]:::entry
    system-prompt["System Prompt\nsrc/constants/prompts.ts"]
    message-history["Message History\nReact state / session.messages"]
    query-engine["Query Engine\nsrc/query.ts"]
    anthropic-api["Anthropic API\n@anthropic-ai/sdk"]:::external
    tool-execution["Tool Execution\nsrc/tools/"]
    compact-system["Compact System\nsrc/compact/"]
    session-log["Session Log\n~/.pi/sessions/{id}/log.jsonl"]:::store
    task-store["Task Store\n~/.pi/tasks/"]:::store
    memory-store["Memory Store\n~/.claude/.../memory/"]:::store

    user-input -->|"appended to"| message-history
    system-prompt -->|"injected at turn start"| query-engine
    message-history -->|"sent as context"| query-engine
    query-engine -->|"streams request to"| anthropic-api
    anthropic-api -->|"streams text + tool_use back"| query-engine
    query-engine -->|"dispatches tool calls to"| tool-execution
    tool-execution -->|"tool_result appended to"| message-history
    tool-execution -->|"agent tasks written to"| task-store
    query-engine -->|"when token limit near, calls"| compact-system
    compact-system -->|"replaces messages in"| message-history
    query-engine -->|"hooks fire events to"| session-log
    tool-execution -->|"memory search reads"| memory-store
